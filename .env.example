# Copy to .env.local and fill in. .env.local is gitignored. NEVER commit real keys.

# --- Client (safe to expose; protected by RLS). Vite exposes VITE_* to the browser. ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # anon/publishable key — the client ships with this

# --- Server-only secrets. NEVER prefix with VITE_. Never reaches the browser. ---
SUPABASE_SECRET_KEY=sb_secret_xxx                  # bypasses RLS — Edge Functions / migrations ONLY
TBA_API_KEY=your_tba_read_key                      # used by the tba-proxy Edge Function
QR_INGEST_HMAC_SECRET=generate_a_random_32b_value  # authenticity for QR-relayed report ingest
